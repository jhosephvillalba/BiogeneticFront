# =========================================================================
# Plantilla de Variables de Entorno - BioGenetic Frontend (Vite)
# Copia este archivo a `.env` y ajusta los valores para tu entorno.
# =========================================================================

# URL base de la API del Backend (FastAPI).
# - En desarrollo con Docker Compose: http://localhost:8000/api
# - En producción: URL pública de la API, ej. https://api.biogenetic.com.co/api
VITE_API_URL=http://localhost:8000/api

# Nombre comercial de la aplicación
VITE_APP_NAME=BioGenetic

# Entorno de ejecución (development | production | staging)
# Determina la verbosidad de los logs y la configuración interna
VITE_APP_ENV=development

# Versión del software
VITE_APP_VERSION=1.0.0
